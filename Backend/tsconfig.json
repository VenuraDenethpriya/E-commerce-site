{
    "compilerOptions": {
      "sourceMap": true,
      "outDir": "./dist",
      "rootDir": "./src",
      "strict": true,
      "lib": ["esnext"],
      "esModuleInterop": true,
      "skipLibCheck": true
    },
  "include": [
    "src/**/*"               
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
    "ts-node": {
      "files": true
    }
  }